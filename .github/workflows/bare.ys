!yamlscript/v0

python-preamble-job =::
  runs-on: ${{matrix.config.os}}
  strategy:
    fail-fast: false
    matrix:
      config:
        - {pythonv: '3.14', os: ubuntu-latest}
        - {pythonv: '3.14', os: macos-15-intel}
python-preamble-job-win =::
  runs-on: ${{matrix.config.os}}
  strategy:
    fail-fast: false
    matrix:
      config:
        - {pythonv: '3.14', os: windows-latest, vsenvarch: x64}


setup-env-win =::
  - name: setup env (Visual Studio)
    uses: TheMrMilchmann/setup-msvc-dev@v3
    with:
      arch: ${{matrix.config.vsenvarch}}


python-preamble-steps =::
  - name: install python ${{matrix.config.pythonv}}
    uses: actions/setup-python@v5
    with:
      python-version: ${{matrix.config.pythonv}}
  - name: deps
    run: |
      if [[ "${{matrix.config.os}}" == macos* ]] ; then
         brew install swig
      elif [[ "${{matrix.config.os}}" == windows* ]] ; then
         choco install swig
      fi
      pip install -r requirements.txt
      pip install -r test/requirements.txt


defn python-wheel-steps(name ext create-wheel-cmd)::
  - name:: "------------------- $name"
    run: |
      rm -rf build/ dist/ || echo "no files found"
      pip uninstall -v rapidyaml || echo "was not installed"
  - name:: "create wheel with $create-wheel-cmd"
    run:: |
      $create-wheel-cmd
  - name: install wheel
    run:: "pip install dist/*.$ext"
  - name: test with pytest
    run: python -m pytest -vvv test
  - name: run benchmarks
    run: |
      for file in travis.yml appveyor.yml compile_commands.json ; do
        python bm/bm_parse.py cpp/bm/cases/$file
      done


python-wheel-tests =::
  - :: python-wheel-steps('using source'     'tar.gz' 'python setup.py sdist --formats=gztar')
  - :: python-wheel-steps('using setup.py'   'whl'    'python setup.py bdist_wheel -v')
  - :: python-wheel-steps('using pip'        'whl'    'pip wheel -w dist/ .')
  - :: python-wheel-steps('using pypa/build' 'whl'    'python -m build --wheel')


python-bare-tests =::
  - name: configure
    run: |
      cmake -S cpp -B build -D RYML_PY_DIR=`pwd` \
         -D CMAKE_BUILD_TYPE=Release \
         -D BUILD_SHARED_LIBS=ON \
         -D RYML_DEFAULT_CALLBACK_USES_EXCEPTIONS=ON \
         -D RYML_BUILD_API=ON \
         -D RYML_API_TESTS=ON \
         -D RYML_BUILD_TESTS=ON
  - name: build
    run: |
      cmake --build build -j -v --config Release --target ryml-api-python3
      cp -fv src/ryml/__init__.py build/api/python3/.
      ls -lFpAR build/api/python3/
  - name: test with ctest
    run: |
      export PYTHONPATH=`pwd`/build/api/python3:$PYTHONPATH
      cmake --build build -j -v --config Release --target ryml-api-test-python3
  - name: test with pytest
    run: |
      export PYTHONPATH=`pwd`/build/api/python3:$PYTHONPATH
      python -m pytest -vvv test
  - name: run benchmarks with cmake
    run: |
      export PYTHONPATH=`pwd`/build/api/python3:$PYTHONPATH
      for file in travis.yml appveyor.yml compile_commands.json ; do
        python bm/bm_parse.py cpp/bm/cases/$file
      done


---
!yamlscript/v0:

:use common: :all
:: workflow-setup()

jobs:

  #----------------------------------------------------
  # verify that we can explicitly run the python API
  # without creating or installing a wheel
  pybare:
    :: setup-job('bare' 'pybare')
    name: pybare/${{matrix.config.pythonv}}/${{matrix.config.os}}
    :: python-preamble-job
    steps:
    - :: checkout-action
    - :: python-preamble-steps
    - :: python-bare-tests

  #----------------------------------------------------
  # run tests with built+installed wheels
  pywheel:
    :: setup-job('bare' 'pywheel')
    name: pywheel/${{matrix.config.pythonv}}/${{matrix.config.os}}
    :: python-preamble-job
    env:
       CMAKE_FLAGS: -DCMAKE_BUILD_TYPE=Release -DCMAKE_VERBOSE_MAKEFILES=ON
    steps:
    - :: checkout-action
    - :: python-preamble-steps
    - :: python-wheel-tests
  pywheelwin:
    :: setup-job('bare' 'pywheel_win')
    name: pywheel/${{matrix.config.pythonv}}/${{matrix.config.os}}
    :: python-preamble-job-win
    env:
       CMAKE_FLAGS: -DCMAKE_BUILD_TYPE=Release -DCMAKE_VERBOSE_MAKEFILES=ON
    steps:
    - :: checkout-action
    - :: python-preamble-steps
    - :: setup-env-win
    - :: python-wheel-tests
